AIRFLOW_UID=0
AIRFLOW_GID=0

# Optional: Kaggle credentials (if you want real Kaggle downloads)
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# Optional: OpenWeatherMap API key (free tier)
# OPENWEATHER_API_KEY=your_key

# Optional: TransitLand API key
# TRANSITLAND_API_KEY=your_key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
PRODUCE_INTERVAL_MS=500

# DuckDB
DUCKDB_PATH=/opt/airflow/data/duckdb/urban_intelligence.duckdb
